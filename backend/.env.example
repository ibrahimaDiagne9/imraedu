# Email Delivery Configuration (SMTP)
# To send real emails, change EMAIL_BACKEND to smtp.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Example for Gmail:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_16_digit_app_password
# DEFAULT_FROM_EMAIL=ImraEdu <your_email@gmail.com>

# Example for SendGrid/Mailgun/etc:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your_api_key
# DEFAULT_FROM_EMAIL=ImraEdu <noreply@imraedu.com>
