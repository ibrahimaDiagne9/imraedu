# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (leave trailing slash)
# For production: https://your-render-backend.onrender.com/api/
VITE_API_URL=http://localhost:8000/api/

# Google OAuth2 Client ID (from Google Cloud Console)
# Docs: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Apple Sign-In Client ID (from Apple Developer Portal - Service ID)
VITE_APPLE_CLIENT_ID=com.imraedu.web
APPLE_CLIENT_ID=com.imraedu.web
